{
  "name": "rockecho",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:sandbox": "wrangler pages dev dist --d1=rockecho-production --local --ip 0.0.0.0 --port 3000",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "wrangler pages dev dist",
    "deploy": "npm run build && wrangler pages deploy dist",
    "deploy:prod": "npm run build && wrangler pages deploy dist --project-name rockecho",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:migrate:local": "wrangler d1 migrations apply rockecho-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply rockecho-production",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local"
  },
  "dependencies": {
    "hono": "^4.12.8",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260312.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-dev-server": "^0.18.2",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.8.2",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}